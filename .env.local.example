DATABASE_URL="mysql://root:root@localhost:3306/odentara_local"
JWT_SECRET="odentara_local_secret_2026"
PORT=3001
APP_URL="http://localhost:3001"

# Email (opcional en desarrollo — si no está configurado, el link se imprime en consola)
# Producción (Hostinger): smtp.hostinger.com, puerto 465, SMTP_SECURE=true
# Desarrollo local: usar Mailtrap o Gmail con App Password
# SMTP_HOST="smtp.hostinger.com"
# SMTP_PORT=465
# SMTP_SECURE="true"
# SMTP_USER="noreply@odentara.com"
# SMTP_PASS="..."
# SMTP_FROM="Odentara <noreply@odentara.com>"

# Destino de las solicitudes de demo desde la landing (default: contacto@odentara.com)
# CONTACT_EMAIL="contacto@odentara.com"

# Recordatorios automáticos de turno (default: 24 horas antes)
# REMINDER_HOURS_BEFORE=24
