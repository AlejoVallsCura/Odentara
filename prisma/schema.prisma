generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum RoleCode {
  superadmin
  admin
  secretary
  professional
}

enum AppointmentStatus {
  not_sent
  sent
  confirmed
  rescheduled
  cancelled
}

enum ConfirmationChannel {
  whatsapp
  phone
  email
  manual
}

enum BillingEntryType {
  income
  debt
  payment
  adjustment
}

enum ScheduleExceptionType {
  unavailable
  special_hours
}

enum OdontogramStatus {
  healthy
  caries
  restored
  absent
  implant
  crown
  crown_implant
  endodontics
  orthodontics
  sealant
}

enum ToothFace {
  M
  D
  V
  P
  O
  I
  L
}

enum AuditAction {
  create
  update
  delete
  login
  logout
}

model Clinic {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String   @unique
  address       String?
  phone         String?
  email         String?
  logoUrl       String?
  active        Boolean  @default(true)
  plan          String?
  notes         String?  @db.Text
  dbType        String   @default("shared")   // "shared" | "dedicated"
  databaseUrl   String?  @db.Text             // solo si dbType = "dedicated"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users                User[]
  professionals        Professional[]
  patients             Patient[]
  appointments         Appointment[]
  subscriptionPayments SubscriptionPayment[]

  @@index([active])
}

model SubscriptionPayment {
  id            Int      @id @default(autoincrement())
  clinicId      Int
  period        String   @db.VarChar(7)   // "2026-05"
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String   @db.VarChar(50)  // efectivo | transferencia | tarjeta | otro
  paidAt        DateTime
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  clinic        Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, period])
  @@index([clinicId])
  @@index([period])
}

model User {
  id                       Int                     @id @default(autoincrement())
  email                    String                  @unique
  passwordHash             String?                 @db.VarChar(255)
  fullName                 String
  active                   Boolean                 @default(true)
  isPlatformAdmin          Boolean                 @default(false)
  clinicId                 Int?
  deletedAt                DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  clinic                   Clinic?                 @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  roles                    UserRole[]
  createdAppointments      Appointment[]           @relation("AppointmentCreatedBy")
  assignedProfessional     Professional?           @relation("ProfessionalUser")
  professionalScopes       UserProfessionalScope[]
  uploadedClinicalImages   ClinicalImage[]
  createdTreatments        Treatment[]
  createdBillingEntries    BillingEntry[]
  auditLogs                AuditLog[]
  passwordResetTokens      PasswordResetToken[]

  @@index([clinicId])
  @@index([deletedAt])
  @@index([active, deletedAt])
}

model Role {
  id        Int        @id @default(autoincrement())
  code      RoleCode   @unique
  label     String
  createdAt DateTime   @default(now())
  users     UserRole[]
}

model UserRole {
  userId     Int
  roleId     Int
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model Professional {
  id                  Int                            @id @default(autoincrement())
  clinicId            Int
  fullName            String
  specialty           String?
  email               String?
  phone               String?
  color               String?
  active              Boolean                        @default(true)
  deletedAt           DateTime?
  userId              Int?                           @unique
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
  clinic              Clinic                         @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  user                User?                          @relation("ProfessionalUser", fields: [userId], references: [id], onDelete: SetNull)
  appointments        Appointment[]
  schedules           ProfessionalAvailability[]
  scheduleExceptions  ProfessionalScheduleException[]
  patientTreatments   Treatment[]
  billingEntries      BillingEntry[]
  scopedUsers         UserProfessionalScope[]
  clinicalRecords     ClinicalRecord[]
  clinicalImages      ClinicalImage[]

  @@index([clinicId])
  @@index([clinicId, active])
  @@index([fullName])
  @@index([active])
  @@index([deletedAt])
}

model UserProfessionalScope {
  userId         Int
  professionalId Int
  createdAt      DateTime     @default(now())
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, professionalId])
  @@index([professionalId])
}

model Patient {
  id               Int              @id @default(autoincrement())
  clinicId         Int
  fullName         String
  normalizedName   String
  dni              String
  birthDate        DateTime?
  phone            String?
  email            String?
  address          String?          @db.Text
  insuranceName    String?
  insurancePlan    String?
  credentialNumber String?
  chartNumber      String?
  active           Boolean          @default(true)
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  clinic           Clinic           @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  appointments     Appointment[]
  clinicalRecords  ClinicalRecord[]
  treatments       Treatment[]
  clinicalImages   ClinicalImage[]
  billingEntries   BillingEntry[]

  @@unique([clinicId, dni])
  @@unique([clinicId, chartNumber])
  @@index([clinicId])
  @@index([clinicId, active, deletedAt])
  @@index([fullName])
  @@index([normalizedName])
  @@index([phone])
  @@index([email])
  @@index([deletedAt])
  @@index([active, deletedAt])
}

model Appointment {
  id                     Int                  @id @default(autoincrement())
  clinicId               Int
  patientId              Int
  professionalId         Int
  createdByUserId        Int?
  date                   DateTime
  startTime              DateTime
  durationMinutes        Int
  status                 AppointmentStatus    @default(not_sent)
  isOverbook             Boolean              @default(false)
  confirmationChannel    ConfirmationChannel?
  confirmationSentAt     DateTime?
  confirmationResponseAt DateTime?
  cancellationReason     String?              @db.Text
  notes                  String?              @db.Text
  deletedAt              DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  clinic                 Clinic               @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patient                Patient              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  professional           Professional         @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  createdByUser          User?                @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  treatments             Treatment[]
  billingEntries         BillingEntry[]

  @@index([clinicId, date])
  @@index([patientId, date])
  @@index([professionalId, date])
  @@index([status, date])
  @@index([date, startTime])
  @@index([deletedAt])
}

model ProfessionalAvailability {
  id             Int          @id @default(autoincrement())
  professionalId Int
  weekday        Int
  startTime      String
  endTime        String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, weekday, startTime, endTime])
  @@index([professionalId, weekday])
}

model ProfessionalScheduleException {
  id             Int                   @id @default(autoincrement())
  professionalId Int
  date           DateTime
  type           ScheduleExceptionType
  startTime      String?
  endTime        String?
  reason         String?               @db.Text
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  professional   Professional          @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, date])
}

model ClinicalRecord {
  id                Int               @id @default(autoincrement())
  patientId         Int
  professionalId    Int?
  summaryNotes      String?           @db.Text
  allergies         String?           @db.Text
  medicalNotes      String?           @db.Text
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  patient           Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional      Professional?     @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  odontogramEntries OdontogramEntry[]

  @@unique([patientId, professionalId])
  @@index([professionalId])
}

model OdontogramEntry {
  id               Int              @id @default(autoincrement())
  clinicalRecordId Int
  toothNumber      String
  face             ToothFace?
  status           OdontogramStatus
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  clinicalRecord   ClinicalRecord   @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)

  @@index([clinicalRecordId, toothNumber])
  @@unique([clinicalRecordId, toothNumber, face])
}

model Treatment {
  id                  Int           @id @default(autoincrement())
  patientId           Int
  professionalId      Int?
  appointmentId       Int?
  createdByUserId     Int?
  tooth               String?
  face                String?
  sector              String?
  authorizationNumber String?
  insuranceCode       String?
  observations        String?       @db.Text
  performedAt         DateTime      @default(now())
  deletedAt           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  patient             Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional        Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  appointment         Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdByUser       User?         @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([patientId, performedAt])
  @@index([professionalId, performedAt])
  @@index([appointmentId])
  @@index([deletedAt])
}

model ClinicalImage {
  id               Int           @id @default(autoincrement())
  patientId        Int
  professionalId   Int?
  uploadedByUserId Int?
  imageUrl         String        @db.LongText
  description      String?       @db.Text
  takenAt          DateTime?
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  patient          Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional     Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  uploadedByUser   User?         @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([patientId, createdAt])
  @@index([patientId, professionalId])
  @@index([deletedAt])
}

model BillingEntry {
  id               Int              @id @default(autoincrement())
  patientId        Int
  professionalId   Int
  appointmentId    Int?
  createdByUserId  Int?
  type             BillingEntryType
  amount           Decimal          @db.Decimal(12, 2)
  currency         String           @default("ARS") @db.VarChar(3)
  description      String?          @db.Text
  date             DateTime
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional     Professional     @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  appointment      Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdByUser    User?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([patientId, date])
  @@index([professionalId, date])
  @@index([type, date])
  @@index([deletedAt])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  token     String    @unique @db.VarChar(64)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  userId      Int?
  entityType  String
  entityId    String
  action      AuditAction
  beforeData  Json?
  afterData   Json?
  createdAt   DateTime    @default(now())
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId, createdAt])
}
