generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleCode {
  superadmin
  admin
  secretary
  professional
}

enum AppointmentStatus {
  not_sent
  sent
  confirmed
  rescheduled
  cancelled
}

enum ConfirmationChannel {
  whatsapp
  phone
  email
  manual
}

enum BillingEntryType {
  income
  debt
  payment
  adjustment
}

enum ScheduleExceptionType {
  unavailable
  special_hours
}

enum OdontogramStatus {
  healthy
  caries
  restored
  absent
}

enum ToothFace {
  M
  D
  V
  P
  O
  I
  L
}

enum AuditAction {
  create
  update
  delete
  login
  logout
}

model User {
  id                       Int                     @id @default(autoincrement())
  email                    String                  @unique
  passwordHash             String?
  fullName                 String
  active                   Boolean                 @default(true)
  deletedAt                DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  roles                    UserRole[]
  createdAppointments      Appointment[]           @relation("AppointmentCreatedBy")
  assignedProfessional     Professional?           @relation("ProfessionalUser")
  professionalScopes       UserProfessionalScope[]
  uploadedClinicalImages   ClinicalImage[]
  createdTreatments        Treatment[]
  createdBillingEntries    BillingEntry[]
  auditLogs                AuditLog[]
}

model Role {
  id        Int        @id @default(autoincrement())
  code      RoleCode   @unique
  label     String
  createdAt DateTime   @default(now())
  users     UserRole[]
}

model UserRole {
  userId     Int
  roleId     Int
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model Professional {
  id                  Int                            @id @default(autoincrement())
  fullName            String
  specialty           String?
  email               String?                        @unique
  phone               String?
  color               String?
  active              Boolean                        @default(true)
  deletedAt           DateTime?
  userId              Int?                           @unique
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
  user                User?                          @relation("ProfessionalUser", fields: [userId], references: [id], onDelete: SetNull)
  appointments        Appointment[]
  schedules           ProfessionalAvailability[]
  scheduleExceptions  ProfessionalScheduleException[]
  patientTreatments   Treatment[]
  billingEntries      BillingEntry[]
  scopedUsers         UserProfessionalScope[]

  @@index([fullName])
  @@index([active])
  @@index([deletedAt])
}

model UserProfessionalScope {
  userId         Int
  professionalId Int
  createdAt      DateTime     @default(now())
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, professionalId])
  @@index([professionalId])
}

model Patient {
  id              Int              @id @default(autoincrement())
  fullName        String
  normalizedName  String
  dni             String           @unique
  birthDate       DateTime?
  phone           String?
  email           String?
  address         String?
  insuranceName   String?
  insurancePlan   String?
  credentialNumber String?
  chartNumber     String?          @unique
  active          Boolean          @default(true)
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  appointments    Appointment[]
  clinicalRecord  ClinicalRecord?
  treatments      Treatment[]
  clinicalImages  ClinicalImage[]
  billingEntries  BillingEntry[]

  @@index([fullName])
  @@index([normalizedName])
  @@index([phone])
  @@index([deletedAt])
}

model Appointment {
  id                    Int                  @id @default(autoincrement())
  patientId             Int
  professionalId        Int
  createdByUserId       Int?
  date                  DateTime
  startTime             DateTime
  durationMinutes       Int
  status                AppointmentStatus    @default(not_sent)
  isOverbook            Boolean              @default(false)
  confirmationChannel   ConfirmationChannel?
  confirmationSentAt    DateTime?
  confirmationResponseAt DateTime?
  cancellationReason    String?
  notes                 String?
  deletedAt             DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  patient               Patient              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  professional          Professional         @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  createdByUser         User?                @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  treatments            Treatment[]
  billingEntries        BillingEntry[]

  @@index([patientId, date])
  @@index([professionalId, date])
  @@index([status, date])
  @@index([date, startTime])
  @@index([deletedAt])
}

model ProfessionalAvailability {
  id             Int          @id @default(autoincrement())
  professionalId Int
  weekday        Int
  startTime      String
  endTime        String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, weekday, startTime, endTime])
  @@index([professionalId, weekday])
}

model ProfessionalScheduleException {
  id             Int                   @id @default(autoincrement())
  professionalId Int
  date           DateTime
  type           ScheduleExceptionType
  startTime      String?
  endTime        String?
  reason         String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  professional   Professional          @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, date])
}

model ClinicalRecord {
  id               Int          @id @default(autoincrement())
  patientId        Int          @unique
  summaryNotes     String?
  allergies        String?
  medicalNotes     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  patient          Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  odontogramEntries OdontogramEntry[]
}

model OdontogramEntry {
  id               Int             @id @default(autoincrement())
  clinicalRecordId Int
  toothNumber      String
  face             ToothFace?
  status           OdontogramStatus
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  clinicalRecord   ClinicalRecord  @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)

  @@index([clinicalRecordId, toothNumber])
  @@unique([clinicalRecordId, toothNumber, face])
}

model Treatment {
  id                   Int           @id @default(autoincrement())
  patientId            Int
  professionalId       Int?
  appointmentId        Int?
  createdByUserId      Int?
  tooth                String?
  face                 String?
  sector               String?
  authorizationNumber  String?
  insuranceCode        String?
  observations         String?
  performedAt          DateTime      @default(now())
  deletedAt            DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  patient              Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional         Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  appointment          Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdByUser        User?         @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([patientId, performedAt])
  @@index([professionalId, performedAt])
  @@index([appointmentId])
  @@index([deletedAt])
}

model ClinicalImage {
  id               Int       @id @default(autoincrement())
  patientId        Int
  uploadedByUserId Int?
  imageUrl         String
  description      String?
  takenAt          DateTime?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  patient          Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedByUser   User?     @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([patientId, createdAt])
  @@index([deletedAt])
}

model BillingEntry {
  id               Int              @id @default(autoincrement())
  patientId        Int
  professionalId   Int?
  appointmentId    Int?
  createdByUserId  Int?
  type             BillingEntryType
  amount           Decimal          @db.Decimal(12, 2)
  currency         String           @default("ARS")
  description      String?
  date             DateTime
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional     Professional?    @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  appointment      Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdByUser    User?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([patientId, date])
  @@index([professionalId, date])
  @@index([type, date])
  @@index([deletedAt])
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  userId      Int?
  entityType  String
  entityId    String
  action      AuditAction
  beforeData  Json?
  afterData   Json?
  createdAt   DateTime    @default(now())
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId, createdAt])
}
